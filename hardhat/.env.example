# ─────────────────────────────────────────────────────────────────────────────
#  Ritual Chain deployment environment
# ─────────────────────────────────────────────────────────────────────────────
#  Copy this file to `.env` (which is gitignored) and fill in the values.
#
#      cp .env.example .env
#
#  ⚠️  NEVER commit the real `.env` file or paste a private key anywhere public.
#      The `.env` pattern is already ignored in hardhat/.gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Private key of the funded account used to deploy to Ritual Chain.
# Used by the `ritual` network in hardhat.config.ts and by scripts/deploy.ts.
# Format: 0x-prefixed 32-byte hex string.
DEPLOYER_PRIVATE_KEY=

# Ritual Chain JSON-RPC endpoint and chain id (defaults shown).
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_CHAIN_ID=1979

# Optional — Sepolia deployment (used by the `sepolia` network in hardhat.config.ts).
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
